{
  "name": "tdd-workflow",
  "version": "3.10.0",
  "description": "TDD Workflow CLI — install TDD skills for AI coding tools",
  "type": "module",
  "bin": {
    "tdd-workflow": "bin/tdd.js"
  },
  "files": [
    "bin/",
    "dist/",
    "skills/"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
