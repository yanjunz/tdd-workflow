  "dependencies": {
    "commander": "^14.0.0",
    "chalk": "^5.4.0",
    "@inquirer/prompts": "^7.5.0",
    "ora": "^8.2.0"
  },
  "devDependencies": {
    "typescript": "^5.8.0",
    "@types/node": "^22.0.0"
  }
}
